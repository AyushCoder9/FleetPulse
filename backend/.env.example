# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# dev.py uses SQLite by default — override here for local Postgres:
# DATABASE_URL=postgresql://fleetpulse:fleetpulse@localhost:5432/fleetpulse

# ── Celery / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Superuser (used by: manage.py createsuperuser --noinput) ──────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@fleetpulse.com
DJANGO_SUPERUSER_PASSWORD=password
